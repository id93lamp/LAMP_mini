# ── LLM Backends ─────────────────────────────────────────────────────────────
# Set ONE of the following, then set PROVER_BACKEND to the matching backend.

# Anthropic Claude  (recommended — full tool-use support)
CLAUDE_API_KEY=your_claude_api_key_here

# Moonshot AI Kimi K2  (OpenAI-compatible, temperature must be 1)
KIMI_API_KEY=your_kimi_api_key_here

# DeepSeek  (OpenAI-compatible)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# ── Active backend ────────────────────────────────────────────────────────────
# Choose one: CLAUDE | KIMI | DEEPSEEK
PROVER_BACKEND=CLAUDE

# ── Prover mode ───────────────────────────────────────────────────────────────
# cow    → paper's main contribution: CoW library-grounded multi-agent proving
# normal → generic Mathlib mode (no CoW library injection)
PROVER_MODE=cow

# ── LeanExplore (optional) ────────────────────────────────────────────────────
# API key for the LeanExplore Mathlib search service (https://leanexplore.com).
# Leave empty to use the local backend (slower but no key required).
LEAN_EXPLORE_API_KEY=
